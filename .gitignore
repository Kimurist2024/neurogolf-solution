# ============================================================
#  NeuroGolf 2026 — .gitignore
#  方針: 自作のコード・スコア・最終 submission.zip のみ追跡。
#        機密 / 生成物 / 大容量データ / 仮想環境は全て除外。
# ============================================================

# --- 機密・認証情報(防御的に広めに除外) ---
.env
.env.*
*.local.yaml
*.local.yml
*.local.json
# .claude/settings.local.json は機密を含まないため明示的に追跡する
!.claude/settings.local.json
*.key
*.pem
*.pfx
credentials*
secret*
*secret*
*apikey*
*api_key*
*.token

# --- Python 仮想環境 / キャッシュ ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- OS / エディタの一時ファイル ---
.DS_Store
*.swp
*.swo
*.tmp
*~
.band_specs.tmp
.kimi_specs.tmp

# --- コンペ公式データ(Kaggle からDL可・大容量) ---
inputs/

# --- 生成物 / 成果物 / 中間出力(大容量) ---
artifacts/
submission/
# others/ は明示的にpush対象(2026-07-16)
scripts/golf/scratch/
scripts/golf/scratch_kimi/
scripts/golf/scratch_codex/
scripts/golf/scratch_claude/

# --- 生成された ONNX モデル ---
*.onnx

# --- アーカイブは原則除外し、最終提出だけ残す ---
*.zip
!submission.zip

# --- 迷子の出力ファイル ---
/--task

# --- 一時バックアップ / スクラッチ status(2026-06-28 追加) ---
*.bak
*.bak_*
*.bak2_*
*.bak3_*
*.bak4_*
*.bak5_*
all_scores.csv.bak*
/_*.txt

# --- ONNX profiling noise ---
onnxruntime_profile__*.json
/--json
/--task-ids
/a.csv

# --- 大容量スクラッチログ(GitHub 100MB上限対策・2026-07-16) ---
scripts/golf/scratch_codex_plus10/
scripts/golf/loop_*/lane_*/diff_audit.json
scripts/golf/loop_*/lane_harvest/external_*.log
*.stderr

# --- scratch 全variant + 大容量ログ(2026-07-16 push対策) ---
scripts/golf/scratch*/
artifacts/
*.stderr.log
*.stderr

# --- others/ 配下は push 対象(onnx/zip の全体除外を打ち消す) ---
!others/**/*.onnx
!others/**/*.zip
